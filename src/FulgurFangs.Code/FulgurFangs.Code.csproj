  <Target Name="CopyHarmony" AfterTargets="Build">
    <Copy
      SourceFiles="$(NuGetPackageRoot)lib.harmony\2.3.3\lib\net48\0Harmony.dll"
      DestinationFolder="$(OutputPath)"
      SkipUnchangedFiles="true" />
  </Target>

  <Target Name="RemoveLegacyFrameworkOutput" AfterTargets="Build">
    <RemoveDir Directories="$(OutputPath)netstandard2.1" Condition="Exists('$(OutputPath)netstandard2.1')" />
  </Target>
</Project>
