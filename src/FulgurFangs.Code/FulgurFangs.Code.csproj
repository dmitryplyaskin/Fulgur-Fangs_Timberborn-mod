    </Reference>
    <Reference Include="Timberborn.Buildings">
      <HintPath>$(TimberbornManagedDir)\Timberborn.Buildings.dll</HintPath>
    </Reference>
    <Reference Include="Timberborn.BuildingRange">
      <HintPath>$(TimberbornManagedDir)\Timberborn.BuildingRange.dll</HintPath>
    </Reference>
    <Reference Include="Timberborn.Common">
